# ─── Anthropic ──────────────────────────────────────────────
# Get a key at https://console.anthropic.com/
# NOTE (see CLAUDE.md §3): Anthropic accounts can have multiple workspaces;
# each workspace has its own credit pool. If you see a "credit balance too
# low" error, make sure this key belongs to a funded workspace.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ─── Discord ────────────────────────────────────────────────
# Create webhooks in your server: Channel settings → Integrations → Webhooks

# Urgent-alert channel (CRITICAL/HIGH/MEDIUM/LOW + heartbeat + battery embeds).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME

# Optional second channel for the per-snap "feed": every snap posted with the
# JPEG attached + Claude's vision text. Designed for sharing / observing the
# system reasoning. Leave empty to disable. Runs ISOLATED from the alert hot
# path (bounded queue + worker; never blocks alerts).
DISCORD_FEED_WEBHOOK_URL=

# Optional THIRD channel for aggregated behavior analytics (every N hours).
# Reports: foraging trip count + durations, % time on/off nest, threat
# events, alert summary, system health. Pure SQLite aggregation, zero
# extra Anthropic spend. Compute runs on a dedicated ThreadPoolExecutor
# so it never blocks the alert or feed paths. Leave empty to disable.
DISCORD_ANALYTICS_WEBHOOK_URL=

# Dedicated test-run webhook for `TEST_MODE=true pytest`. REQUIRED for the
# integration test suite — all [TEST] traffic (alerts + feed + analytics)
# is rewritten to route here so it never pollutes the live production
# channels. See CLAUDE.md §18. If unset, the integration-test autouse
# fixture hard-fails with a clear error.
DISCORD_TEST_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME

# NEW 2026-04-15: backfill channel for alerts fired on STALE snaps that
# the analyzer processes late (e.g. during/after analyzer-service downtime
# in the two-service architecture). Keeps post-hoc alerts out of the live
# urgent channel so you don't confuse them with real-time events. Empty =
# backfill alerts are suppressed entirely.
DISCORD_BACKFILL_WEBHOOK_URL=

# Dedicated channel for lifecycle celebrations (🐣 hatch / 🦅 fledge).
# When set, hatch/fledge LOW alerts route here instead of the urgent
# #alerts channel, keeping the urgent channel reserved for threats.
# Empty = lifecycle alerts go to the urgent channel (fallback).
DISCORD_LIFECYCLE_WEBHOOK_URL=

ANALYTICS_REPORT_HOURS=8
# Wall-clock hour (local time, 0-23) to post a daily 24-hour summary
# in ADDITION to the drifting 8h cadence. Set to -1 to disable.
ANALYTICS_DAILY_HOUR=8

# ─── Blink ──────────────────────────────────────────────────
# Used ONLY for first-run 2FA. After auth, the persisted
# blink_credentials.json takes over and these are unused.
BLINK_USERNAME=you@example.com
BLINK_PASSWORD=REPLACE_ME

# Exact camera name as shown in the Blink mobile app.
BLINK_CAMERA_NAME=YOUR_CAMERA

# ─── Cadence ────────────────────────────────────────────────
SNAP_INTERVAL_SECONDS=300
MOTION_POLL_SECONDS=15
ACTIVE_HOURS=00:00-23:59

# Optional quiet-hours window (LOCAL time on the host machine).
# During this window, snap_loop uses QUIET_SNAP_INTERVAL_SECONDS instead.
# Motion events still trigger immediate snaps regardless of cadence.
# Empty = disabled. Wraparound (e.g. 23:00-05:00) supported.
QUIET_HOURS=23:00-05:00
QUIET_SNAP_INTERVAL_SECONDS=1800

# Pattern A — absence-aware cadence. When state.in_absence=True (mom has
# been off the nest ≥ 2 min by our tracker), snap this frequently instead
# of SNAP_INTERVAL_SECONDS. Rationale: mom-absent is the peak predation
# window (predators know she's gone). Tight cadence only while at risk.
# Quiet hours override this — even if in_absence, we stick to QUIET
# cadence from 23:00–05:00 to save battery overnight.
ABSENCE_SNAP_INTERVAL_SECONDS=60

# Burst cadence — ultra-tight interval for the first N seconds after mom
# leaves the nest. Peak predation-risk window (thrasher attacks can be
# ~4 s events that a 60s absence cadence would miss). When in_absence
# flips True, cadence drops to BURST_SNAP_INTERVAL_SECONDS for
# BURST_DURATION_SECONDS, then relaxes back to ABSENCE_SNAP_INTERVAL_SECONDS
# if mom is still away. Quiet hours override burst (we stay sparse
# overnight). Defaults: 30s / 180s (3 min).
BURST_SNAP_INTERVAL_SECONDS=30
BURST_DURATION_SECONDS=180

# ─── Lifecycle tracking (2026-04-16, default ON) ────────────
# 6-stage detection: building_nest → egg_laying → incubation → feeding →
# fledging → empty. Auto-transitions are inferred from observation history
# (e.g. egg_laying → incubation when ≥70% sitting ratio over a 24h window).
# When True (the default), the system:
#   • Fires a 🥚 LOW alert when egg-laying begins
#   • Fires a 🪺 LOW alert when sustained incubation is confirmed
#   • Fires a 🐣 LOW alert when chick presence is confirmed (2-sighting guard)
#   • Fires a 🦅 LOW alert when chicks fledge
#   • Suppresses MEDIUM absence alerts during the feeding stage (mom is
#     expected to be away foraging for chicks)
#   • Suppresses MEDIUM absence alerts overnight during egg_laying (laying
#     cardinals do not incubate; absence is normal until the last egg is down)
# All four lifecycle alerts route to DISCORD_LIFECYCLE_WEBHOOK_URL when set,
# keeping the urgent #alerts channel reserved for actual threats.
# Set to false as an escape hatch if a false positive fires (no code deploy
# needed). See CLAUDE.md §23.
LIFECYCLE_TRACKING_ENABLED=true

# ─── Models ─────────────────────────────────────────────────
# Single-tier architecture: the ANALYZER runs on every snap.
# PREFILTER_MODEL is kept for backward compat but currently unused —
# we dropped the Haiku prefilter tier after finding it escalated most
# snaps anyway and its IR-image accuracy was worse than Sonnet's.
PREFILTER_MODEL=claude-haiku-4-5-20251001
ANALYZER_MODEL=claude-sonnet-4-6

# Blind second-opinion model for CRITICAL/HIGH alerts. When Sonnet flags
# an alert, Opus independently re-analyzes the same image with no hint of
# Sonnet's verdict (to avoid anchoring bias). If Opus disagrees, alert is
# suppressed or downgraded. Adds ~3–6s latency + ~$0.05 per alert fired.
# Set VERIFY_ALERTS_WITH_OPUS=false to disable.
VERIFICATION_MODEL=claude-opus-4-6
VERIFY_ALERTS_WITH_OPUS=true

# ─── Operational ────────────────────────────────────────────
BATTERY_REPORT_HOURS=6
HEARTBEAT_HOUR_LOCAL=12
LOG_LEVEL=INFO

# Force an Opus ground-truth call at least every N seconds even when Haiku
# says "no novel activity." Bounds the worst-case blind window if Haiku
# consistently misclassifies (e.g. IR-image cardinal hallucinations).
# Unused in single-tier mode (no tier escalation to force), but kept for
# easy re-enable if the prefilter tier is restored. Set to 0 to disable.
FORCED_OPUS_INTERVAL_SECONDS=900

# ─── Two-service architecture (NEW 2026-04-15) ─────────────
# "combined" (default) preserves the original single-process behavior.
# Phase 2 deploy splits the pipeline into two processes:
#   "downloader" — Blink → spool (atomic-rename JPEG queue on disk)
#   "analyzer"   — spool  → Anthropic → Discord
# Normally set via the --role CLI flag or the launchd plist; this env
# var is an escape hatch for local runs / testing.
ROLE=combined

# Snaps in the spool older than this are dropped on analyzer startup.
# Cost cap: prevents a recovery burst from burning through Anthropic
# credits replaying an overnight backlog. Default 1800s (30 min).
BACKFILL_MAX_AGE_SECONDS=1800

# Snaps younger than this route to the urgent DISCORD_WEBHOOK_URL (live);
# older snaps route to DISCORD_BACKFILL_WEBHOOK_URL (post-hoc). Keeps the
# live channel uncontaminated by late-processed events.
BACKFILL_LIVE_THRESHOLD_SECONDS=30

# ─── Paths ──────────────────────────────────────────────────
# All gitignored. Overrideable for tests.
DATA_DIR=./data
EVIDENCE_DIR=./evidence
# Spool directory for the decoupled downloader/analyzer (atomic-rename
# queue). The downloader writes JPEGs here; the analyzer consumes them.
SPOOL_DIR=./data/spool
BLINK_CREDS_PATH=./blink_credentials.json
PAUSE_LOCK_PATH=./pause.lock
